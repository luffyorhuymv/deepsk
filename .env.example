# Copy to .env and fill in real values. .env is gitignored.

# Cloudflare tunnel token (get from Cloudflare Zero Trust dashboard)
CLOUDFLARE_TUNNEL_TOKEN=your-tunnel-token-here

# Open WebUI - API key gửi tới proxy. Để trống nếu proxy chưa có key active.
OPENAI_API_KEY=sk-no-auth-needed

# Open WebUI - bật/tắt đăng nhập
WEBUI_AUTH=true

# Open WebUI - secret key cho session. Đặt random string để giữ session qua các restart.
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBUI_SECRET_KEY=change-me-to-random-string
